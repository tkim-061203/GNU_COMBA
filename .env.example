# ============================================================================
#  GNU_COMBA — LLM connection config (.env)
# ----------------------------------------------------------------------------
#  Loaded automatically by run.py / benchmark_langgraph.py via python-dotenv.
#  The pipeline talks to ANY OpenAI-compatible /v1 endpoint through the OpenAI
#  SDK (see src/langgraph_core/llm_interface.py -> COMBALlm.from_env()), so the
#  same 6 variables cover OpenAI, OpenRouter, Together, Groq, vLLM and Ollama.
#
#  Resolution order in create_llm():
#    1. COMBA_USE_STUB=1                -> StubLLM (offline test, no network)
#    2. COMBALlm.from_env()  <-- ACTIVE -> single OR dual OpenAI-compatible API
#    3. ChatOpenAI fallback             -> uses LLM_BASE_URL/LLM_API_KEY/LLM_MODEL
#
#  IMPORTANT for a SINGLE remote provider (OpenAI/OpenRouter/...):
#    - Leave LLM_DEBUGGER_URL EMPTY so server_mode="single"
#      (if it is non-empty the pipeline runs in "dual" mode and routes the
#       debugger step to LLM_MODEL_DEBUGGER on that URL).
#    - Set LLM_MODEL_DEBUGGER to the SAME model as LLM_MODEL_BASE, otherwise the
#      debugger route asks the provider for a model literally named "debugger".
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
#  ACTIVE PROFILE: OpenAI  (paste your key below, then run `make RTLLM`)
# ─────────────────────────────────────────────────────────────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...your-key-here...
LLM_MODEL=gpt-4o-mini
LLM_MODEL_BASE=gpt-4o-mini
LLM_MODEL_DEBUGGER=gpt-4o-mini
LLM_DEBUGGER_URL=

# ─────────────────────────────────────────────────────────────────────────────
#  ALTERNATIVE PROFILES — comment out the block above, uncomment ONE below.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenRouter (access many models behind one OpenAI-compatible API) ─────────
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-REPLACE
# LLM_MODEL=qwen/qwen-2.5-coder-32b-instruct
# LLM_MODEL_BASE=qwen/qwen-2.5-coder-32b-instruct
# LLM_MODEL_DEBUGGER=qwen/qwen-2.5-coder-32b-instruct
# LLM_DEBUGGER_URL=

# ── Together.ai ──────────────────────────────────────────────────────────────
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=REPLACE
# LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# LLM_MODEL_BASE=Qwen/Qwen2.5-Coder-32B-Instruct
# LLM_MODEL_DEBUGGER=Qwen/Qwen2.5-Coder-32B-Instruct
# LLM_DEBUGGER_URL=

# ── Groq ─────────────────────────────────────────────────────────────────────
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_REPLACE
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_MODEL_BASE=llama-3.3-70b-versatile
# LLM_MODEL_DEBUGGER=llama-3.3-70b-versatile
# LLM_DEBUGGER_URL=

# ── Local Ollama (no key needed) ─────────────────────────────────────────────
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5-coder:7b
# LLM_MODEL_BASE=qwen2.5-coder:7b
# LLM_MODEL_DEBUGGER=qwen2.5-coder:7b
# LLM_DEBUGGER_URL=

# ── Local dual-GPU vLLM (the launch_dual_gpu.sh setup) ───────────────────────
#   GPU0:8000 = generator, GPU1:8001 = debugger. Keep DEBUGGER_URL set for dual.
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_DEBUGGER_URL=http://localhost:8001/v1
# LLM_API_KEY=not-needed
# LLM_MODEL_BASE=generator
# LLM_MODEL_DEBUGGER=debugger

# ─────────────────────────────────────────────────────────────────────────────
#  Benchmark / Best-of-N knobs (optional; Makefile already passes sane defaults)
# ─────────────────────────────────────────────────────────────────────────────
# COMBA_USE_STUB=0              # 1 = offline dry-run with no LLM calls
# COMBA_SELF_CONSISTENCY=1      # best-of-N sampling (Makefile sets SC=1)
# COMBA_MAX_SAMPLES=5           # max samples per module when SC is on
# COMBA_EARLY_EXIT=1            # stop sampling once a candidate passes
# COMBA_PIPELINE_TIMEOUT=600    # per-module wall timeout (s)
# COMBA_WALL_BUDGET=1200        # overall best-of-N wall budget (s)
# COMBA_TS_SIMULATOR=verilator  # verilator | iverilog (Makefile sets verilator)
# COMBA_VCD_HINT=0              # 1/true/on = feed VCD waveform hint to the debugger.
                               #   OFF by default: the hint lowered pass rate on v1 and
                               #   was inconclusive on v2. Turn on only for A/B testing.
