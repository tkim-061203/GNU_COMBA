    "gvd": "module counter_12(\n    input rst_n,\n    input clk,\n    input valid_count,\n    output reg [3:0] out\n); \n    always @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            out <= 4'b0000;\n        end else if (valid_count == 1) begin\n            if (out == 4'd11) begin\n                out <= 4'b0000;\n            end else begin\n                out <= out + 4'b0001;\n            end\n        end\n    end\nendmodule\n",
    "xml_description": "<module id=\"counter_12\">\n    <description>Counter from 0 to 11, controlled by valid_count.</description>\n    <ports>\n        <input id=\"rst_n\">Reset signal (active low)</input>\n        <input id=\"clk\">Clock signal</input>\n        <input id=\"valid_count\">Enable counting</input>\n        <output id=\"out\" width_description=\"[3:0]\">Current count.</output>\n    </ports>\n    <parameter_description>\n        <enum id=\"STATE_0\" value=\"4'd0\">STATE_0 description</enum>\n        <enum id=\"STATE_1\" value=\"4'd1\">STATE_1 description</enum>\n        <enum id=\"STATE_2\" value=\"4'd2\">STATE_2 description</enum>\n        <enum id=\"STATE_3\" value=\"4'd3\">STATE_3 description</enum>\n        <enum id=\"STATE_4\" value=\"4'd4\">STATE_4 description</enum>\n        <enum id=\"STATE_5\" value=\"4'd5\">STATE_5 description</enum>\n        <enum id=\"STATE_6\" value=\"4'd6\">STATE_6 description</enum>\n        <enum id=\"STATE_7\" value=\"4'd7\">STATE_7 description</enum>\n        <enum id=\"STATE_8\" value=\"4'd8\">STATE_8 description</enum>\n        <enum id=\"STATE_9\" value=\"4'd9\">STATE_9 description</enum>\n        <enum id=\"STATE_10\" value=\"4'd10\">STATE_10 description</enum>\n        <enum id=\"STATE_11\" value=\"4'd11\">STATE_11 description</enum>\n    </parameter_description>\n    <logic_description>\n        <sequential_logic id=\"counter\">\n            if (!rst_n) begin\n                <sequential>\n                    <assign id=\"out\" value=\"4'b0000\"/>\n                </sequential>\n            end else if (valid_count == 1) begin\n                <sequential>\n                    <assign id=\"out\" value=\"out == 4'd11 ? 4'b0000 : out + 4'b0001;\"/>\n                </sequential>\n            end\n        </sequential_logic>\n    </logic_description>\n    <task>\n        <description>Reset the counter to 0.</description>\n        <invocation>reset_counter()</invocation>\n        <code>\n            <sequential>\n                <assign id=\"out\" value=\"4'b0000\"/>\n            </sequential>\n        </code>\n    </task>\n</module>",
