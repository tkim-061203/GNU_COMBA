                                        <identifier>en_clap_one</identifier>\n                                                    <assignment>\n                                                        <identifier>data_en</identifier>\n                                                    </assignment>\n                                                </code>\n                                            </else>\n                                        </if>\n                                    </action>\n                                </ppp>\n                            </always>\n                        </code>\n                    </template>\n                </for>\n                <for>\n                    <template>\n                        <code>\n                            <reg id=\"\" width_description=\"[1:0]\">\n                                <init>0</init>\n                                <identifier>en_clap_two</identifier>\n                                <description>Register to control the selection of data_in.</description>\n                            </reg>\n                        </code>\n                    </template>\n                </for>\n                <description>Update the en_clap_two with en_clap_one on the positive edge of clk_b or the negative edge of brstn.</description>\n                <for>\n                    <template>\n                        <code>\n                            <always>\n                                <ppp>\n                                    <condition>\n                                        <and>\n                                            <identifier>clk_b</identifier>\n                                            <operator>==</operator>\n                                            <constant>1'b1</constant>\n                                        </and>\n                                    </condition>\n                                    <action>\n                                        <if>\n                                            <condition>\n                                                <identifier>brstn</identifier>\n                                            </condition>\n                                            <then>\n                                                <code>\n                                                    <identifier>en_clap_two</identifier>\n                                                    <assignment>\n                                                        <constant>1'b0</constant>\n                                                    </assignment>\n                                                </code>\n                                            </then>\n                                            <else>\n                                                <code>\n                                                    <identifier>en_clap_two</identifier>\n                                                    <assignment>\n                                                        <identifier>en_clap_one</identifier>\n                                                    </assignment>\n                                                </code>\n                                            </else>\n                                        </if>\n                                    </action>\n                                </ppp>\n                            </always>\n                        </code>\n                    </template>\n                </for>\n            </item>\n            <item>\n                <description>Fourth, implement a register to store the output data.</description>\n                <for>\n                    <template>\n                        <code>\n                            <reg id=\"\" width_description=\"[3:0]\">\n                                <init>0</init>\n                                <identifier>dataout</identifier>\n                                <description>Register to store the output data