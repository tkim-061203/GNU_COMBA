    "gvd": "module synchronizer(\n    input clk_a, clk_b, arstn, brstn,\n    input [3:0] data_in,\n    input data_en,\n    output reg [3:0] dataout\n);\n\nreg [3:0] sync_data_in;\nreg sync_data_en;\nreg [1:0] sync_data_en_delayed;\n\nalways @(posedge clk_b or negedge brstn) begin\n    if (!brstn) begin\n        sync_data_in <= 4'b0;\n        sync_data_en <= 1'b0;\n        sync_data_en_delayed <= 2'b0;\n    end else begin\n        sync_data_in <= data_in;\n        sync_data_en <= data_en;\n        sync_data_en_delayed <= {sync_data_en_delayed[0], sync_data_en};\n    end\nend\n\nalways @(posedge clk_b or negedge arstn) begin\n    if (!arstn) begin\n        dataout <= 4'b0;\n    end else if (sync_data_en_delayed == 2'b11) begin\n        dataout <= sync_data_in;\n    end\nend\n\nendmodule\n",
    "xml_description": "<module id=\"synchronizer\">\n    <description>Implement a multi-bit MUX-based synchronizer. The data_en input is synchronous to clk_a and the data_in input is constant during the period when data_en is high. So, if data_en is high for at least 3 clk_b cycles, then data_in can be synchronized and held for the next 3 clk_b cycles.</description>\n    <ports>\n        <input id=\"clk_a\">Clock signal A.</input>\n        <input id=\"clk_b\">Clock signal B.</input>\n        <input id=\"arstn\">Active-low reset signal A.</input>\n        <input id=\"brstn\">Active-low reset signal B.</input>\n        <input id=\"data_in\" width_description=\"[3:0]\">Input data signal.</input>\n        <input id=\"data_en\">Input enable signal.</input>\n        <output id=\"dataout\" width_description=\"[3:0]\">Output data signal.</output>\n    </ports>\n    <parameter_description>\n        <enum id=\"state\" type=\"enum\" width_description=\"[1:0]\">\n            <enum_value id=\"S_IDLE\" value=\"2'b00\" description=\"Idle state.\">Idle state.</enum_value>\n            <enum_value id=\"S_ONE\" value=\"2'b01\" description=\"State one.\">State one.</enum_value>\n            <enum_value id=\"S_TWO\" value=\"2'b10\" description=\"State two.\">State two.</enum_value>\n        </enum>\n    </parameter_description>\n    <logic_description>\n        <enum_value id=\"S_IDLE\" value=\"2'b00\" description=\"Idle state.\">Idle state.</enum_value>\n        <enum_value id=\"S_ONE\" value=\"2'b01\" description=\"State one.\">State one.</enum_value>\n        <enum_value id=\"S_TWO\" value=\"2'b10\" description=\"State two.\">State two.</enum_value>\n    </logic_description>\n    <implementation>\n        <parabrahm>\n            <item>\n                <description>First, implement a register to store data_in.</description>\n                <for>\n                    <template>\n                        <code>\n                            <reg id=\"\" width_description=\"[3:0]\">\n                                <init>0</init>\n                                <identifier>data_reg</identifier>\n                                <description>Register to store data_in.</description>\n                            </reg>\n                        </code>\n                    </template>\n                </for>\n                <description>Update the data_reg with data_in on the positive edge of clk_a or the negative edge of arstn.</description>\n                <for>\n                    <template>\n                        <code>\n                            <always>\n                                <ppp>\n                                    <condition>\n                                        <and>\n                                            <identifier>clk_a</identifier>\n                                            <operator>==</operator>\n                                            <constant>1'b1</constant>\n                                        </and>\n                                    </condition>\n                                    <action>\n                                        <if>\n                                            <condition>\n                                                <identifier>arstn</identifier>\n                                            </condition>\n                                            <then>\n                                                <code>\n                                                    <identifier>data_reg</identifier>\n                                                    <assignment>\n                                                        <constant>4'b0000</constant>\n                                                    </assignment>\n                                                </code>\n                                            </then>\n                                            <else>\n                                                <code>\n                                                    <identifier>data_reg</identifier>\n                                                    <assignment>\n                                                        <identifier>data_in</identifier>\n                                                    </assignment>\n                                                </code>\n                                            </else>\n                                        </if>\n                                    </action>\n                                </ppp>\n                            </always>\n                        </code>\n                    </template>\n                </for>\n            </item>\n            <item>\n                <description>Second, implement a register to store the enable signal data_en.</description>\n                <for>\n                    <template>\n                        <code>\n                            <reg id=\"\" width_description=\"[3:0]\">\n                                <init>0</init>\n                                <identifier>en_data_reg</identifier>\n                                <description>Register to store the enable signal data_en.</description>\n                            </reg>\n                        </code>\n                    </template>\n                </for>\n                <description>Update the en_data_reg with data_en on the positive edge of clk_a or the negative edge of arstn.</description>\n                <for>\n                    <template>\n                        <code>\n                            <always>\n                                <ppp>\n                                    <condition>\n                                        <and>\n                                            <identifier>clk_a</identifier>\n                                            <operator>==</operator>\n                                            <constant>1'b1</constant>\n                                        </and>\n                                    </condition>\n                                    <action>\n                                        <if>\n                                            <condition>\n                                                <identifier>arstn</identifier>\n                                            </condition>\n                                            <then>\n                                                <code>\n                                                    <identifier>en_data_reg</identifier>\n                                                    <assignment>\n                                                        <constant>1'b0</constant>\n                                                    </assignment>\n                                                </code>\n                                            </then>\n                                            <else>\n                                                <code>\n                                                    <identifier>en_data_reg</identifier>\n                                                    <assignment>\n                                                        <identifier>data_en</identifier>\n                                                    </assignment>\n                                                </code>\n                                            </else>\n                                        </if>\n                                    </action>\n                                </ppp>\n                            </always>\n                        </code>\n                    </template>\n                </for>\n            </item>\n            <item>\n                <description>Third, implement two registers to control the selection of data_in. The input data_en is synchronous to clk_a, so it can be sampled by clk_b.</description>\n                <for>\n                    <template>\n                        <code>\n                            <reg id=\"\" width_description=\"[1:0]\