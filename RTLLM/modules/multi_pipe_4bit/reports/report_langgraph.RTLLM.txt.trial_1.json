    "xml_description": "<module id=\"multi_pipe_4bit\">\n    <description>Implement a 4-bit unsigned number pipeline multiplier.</description>\n    <ports>\n        <input id=\"clk\">Clock.</input>\n        <input id=\"rst_n\">Active-low reset.</input>\n        <input id=\"mul_a\" width_description=\"[3:0]\">Multiplicand.</input>\n        <input id=\"mul_b\" width_description=\"[3:0]\">Multiplier.</input>\n        <output id=\"mul_out\" width_description=\"[7:0]\">Product.</output>\n    </ports>\n    <parameter_description>\n        <parameter name=\"size\">4</parameter>\n    </parameter_description>\n    <implementation>\n    <task>\n        <description>Extend input signals.</description>\n        <parameter name=\"length\">size</parameter>\n        <parameter name=\"input_a\">mul_a</parameter>\n        <parameter name=\"input_b\">mul_b</parameter>\n        <parameter name=\"output\">out</parameter>\n        <parameter name=\"direction\">LSB</parameter>\n        <parameter name=\"extend\">0</parameter>\n        <parameter name=\"extend_size\">size</parameter>\n        <parameter name=\"extend_direction\">MSB</parameter>\n        <parameter name=\"operation\">\n        <code>\n        out = {{extend_size{extend}}, input_a, input_b};\n        </code>\n        </parameter>\n    </task>\n    <task>\n        <description>Multipliers.</description>\n        <parameter name=\"bit\">bit</parameter>\n        <parameter name=\"input_a\">mul_a</parameter>\n        <parameter name=\"input_b\">mul_b</parameter>\n        <parameter name=\"output\">out</parameter>\n        <parameter name=\"direction\">LSB</parameter>\n        <parameter name=\"extend\">0</parameter>\n        <parameter name=\"extend_size\">size</parameter>\n        <parameter name=\"extend_direction\">MSB</parameter>\n        <parameter name=\"operation\">\n        <code>\n        if (input_b[bit] == 1'b1) begin\n            out = out + ({{extend_size{extend}}, input_a} << bit);\n        end\n        else begin\n            out = out + 'd0;\n        end\n        </code>\n        </parameter>\n    </task>\n    <task>\n        <description>Multipliers.</description>\n        <parameter name=\"bit\">bit</parameter>\n        <parameter name=\"input_a\">mul_a</param>\n        <parameter name=\"input_b\">mul_b</param>\n        <parameter name=\"output\">out</parameter>\n        <parameter name=\"direction\">LSB</parameter>\n        <parameter name=\"extend\">0</parameter>\n        <parameter name=\"extend_size\">size</parameter>\n        <parameter name=\"extend_direction\">MSB</parameter>\n        <parameter name=\"operation\">\n        <code>\n        if (input_b[bit] == 1'b1) begin\n            out = out + ({{extend_size{extend}}, input_a} << bit);\n        end\n        else begin\n            out = out + 'd0;\n        end\n        </code>\n        </parameter>\n    </task>\n    </implementation>\n</module>",
