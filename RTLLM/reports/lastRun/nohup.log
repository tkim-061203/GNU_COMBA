module accu(
    input clk,
    input rst_n,
    input [7:0] data_in,
    input valid_in,
    output reg valid_out,
    output reg [9:0] data_out
);

    reg [9:0] accumulator;
    reg [2:0] count;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            accumulator <= 10'd0;
            count <= 3'd0;
            valid_out <= 1'b0;
            data_out <= 10'd0;
        end else begin
            if (valid_in) begin
                // Accumulate data
                accumulator <= accumulator + data_in;
                count <= count + 1;
                
                // Check if we have received 4 inputs
                if (count == 3'd3) begin
                    data_out <= accumulator + data_in; // Output the accumulated result
                    valid_out <= 1'b1; // Set valid_out high for one cycle
                    // Reset for next accumulation
                    accumulator <= 10'd0;
                    count <= 3'd0;
                end else begin
                    valid_out <= 1'b0; // valid_out remains low until 4th input
                end
            end else begin
                valid_out <= 1'b0; // valid_out is low if valid_in is not set
            end
        end
    end

endmodule
